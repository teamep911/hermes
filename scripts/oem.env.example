# OEM-host environment for the alert dispatcher.
# Copy to /etc/hermes-oem.env (chmod 600), then `source` it before alert_push.sh
# (or load it from the OEM notification method). NEVER commit the real file.

# --- Hermes gateway webhook endpoint (the oem-alert route) ---
export HERMES_URL="http://<hermes-host>:8644/webhooks/oem-alert"

# --- Shared HMAC secret (must equal WEBHOOK_SECRET on the Hermes side) ---
export WEBHOOK_SECRET="change-me-shared-hmac-secret"

# --- Optional: extra exact terms to mask (comma-separated), e.g. SIDs/schemas ---
export MASK_TERMS="ORCLPROD,PAYROLL"

# --- Oracle environment so check_session.sh / awr_export.sh can run sqlplus ---
export ORACLE_HOME="/u01/app/oracle/product/19.0.0/dbhome_1"
export ORACLE_SID="ORCLPROD"
export PATH="$ORACLE_HOME/bin:$PATH"
