# Hermes Agent secrets — install to ~/.hermes/.env (chmod 600).
# All values are placeholders. NEVER commit the real file.

# --- LLM: your own Anthropic key (pay-per-token on your org) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Inbound webhook auth (shared with OEM-side alert_push.sh) ---
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8644
WEBHOOK_SECRET=change-me-shared-hmac-secret

# --- Google Chat (bidirectional: Pub/Sub inbound + Chat REST outbound) ---
# Service account needs roles/pubsub.subscriber on the subscription.
GOOGLE_CHAT_PROJECT_ID=my-chat-bot-123
GOOGLE_CHAT_SUBSCRIPTION_NAME=projects/my-chat-bot-123/subscriptions/hermes-chat-events-sub
GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=/home/hermes/.hermes/google-chat-sa.json
GOOGLE_CHAT_ALLOWED_USERS=you@yourdomain.com
# Space the agent posts alerts into (spaces/AAAA...).
GOOGLE_CHAT_HOME_CHANNEL=spaces/AAAAAAAAAAA
