# Hermes Agent secrets — these keys go in ~/.hermes/.env (chmod 600).
# All values are placeholders. NEVER commit the real file.
#
# NOTE on the model: this deployment uses your EXISTING model config in
# ~/.hermes/config.yaml (provider: custom -> internal OpenAI-compatible
# endpoint). Sensitive Oracle data stays on your own infra. Do not switch it
# to a public provider unless you intend the (already-masked) data to leave.

# --- Inbound webhook auth (shared with the OEM-side alert_push.sh) ---
WEBHOOK_ENABLED=true
WEBHOOK_PORT=8644
WEBHOOK_SECRET=change-me-shared-hmac-secret

# --- Google Chat platform plugin (bidirectional: Pub/Sub in + Chat REST out) ---
# Service account needs roles/pubsub.subscriber on the subscription.
GOOGLE_CHAT_PROJECT_ID=my-chat-bot-123
GOOGLE_CHAT_SUBSCRIPTION_NAME=projects/my-chat-bot-123/subscriptions/hermes-chat-events-sub
GOOGLE_CHAT_SERVICE_ACCOUNT_JSON=/root/.hermes/google-chat-sa.json
GOOGLE_CHAT_ALLOWED_USERS=you@yourdomain.com
# Space the agent posts alerts into (spaces/AAAA...). Used as the delivery
# fallback and the home channel.
GOOGLE_CHAT_HOME_CHANNEL=spaces/AAAAAAAAAAA
