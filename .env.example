# =====================================================================
# Hermes Agent — runtime configuration template
# Copy to .env.runtime (chmod 600). NEVER commit real values.
# All hostnames / IPs / domains below are placeholders.
# =====================================================================

# --- Service ---
HERMES_HOST=0.0.0.0
HERMES_PORT=2020
HERMES_ENV=production
LOG_LEVEL=INFO

# --- Inbound webhook auth (OEM -> Hermes) ---
# Shared secret used for HMAC-SHA256 over the raw request body.
AGENT_WEBHOOK_SECRET=change-me-inbound-secret

# --- Database (PostgreSQL + pgvector) ---
PG_DSN=postgresql://hermes:change-me@127.0.0.1:5432/hermes

# --- LLM routing ---
# Order tried on failure/timeout. Comma-separated subset of: claude,gemini,openrouter
LLM_PRIMARY=claude
LLM_FALLBACKS=gemini,openrouter
LLM_TIMEOUT_SECONDS=45
LLM_MAX_TOKENS=2048

# Anthropic / Claude (default provider)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-opus-4-8

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# OpenRouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-opus-4-8
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# --- Embeddings (for Memory / similar-error recall) ---
# voyage | gemini | hash  (hash = offline deterministic fallback, no API)
EMBEDDING_PROVIDER=hash
EMBEDDING_DIM=1024
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3
MEMORY_TOP_K=5
MEMORY_MIN_SCORE=0.78

# --- Google Chat (outbound) ---
# Incoming-webhook URL of the target space (kept out of VCS).
GOOGLE_CHAT_WEBHOOK_URL=
GOOGLE_CHAT_ENABLED=true

# --- Cost / latency controls ---
# Skip LLM for duplicate signatures seen within this window.
DEDUP_WINDOW_SECONDS=900
# Only call the LLM for alerts at/above this severity.
LLM_MIN_SEVERITY=warning
